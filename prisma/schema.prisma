// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoomType {
  SINGLE
  DOUBLE
  SUITE
}

enum RoomStatus {
  LIBRE
  OCCUPEE
  TRAVAUX
  NETTOYAGE
}

enum Currency {
  EUR
  FCFA
  USD
}

enum ReservationStatus {
  CONFIRMEE
  CHECKIN
  CHECKOUT
  NOSHOW
  ANNULEE
}

enum StayType {
  NUIT
  PASSAGE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("staff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id           Int           @id @default(autoincrement())
  number       String        @unique
  floor        Int
  type         RoomType
  status       RoomStatus    @default(LIBRE)
  price        Decimal       @db.Decimal(10, 2)
  currency     Currency      @default(FCFA)
  guest        Guest?        @relation(fields: [guestId], references: [id])
  guestId      String?       @unique
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Guest {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  phone        String
  email        String?       @unique
  room         Room?
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Reservation {
  id            String               @id @default(uuid())
  guest         Guest                @relation(fields: [guestId], references: [id])
  guestId       String
  room          Room                 @relation(fields: [roomId], references: [id])
  roomId        Int
  checkIn       DateTime
  checkOut      DateTime
  stayType      StayType             @default(NUIT)
  durationHours Int?
  status        ReservationStatus    @default(CONFIRMEE)
  totalAmount   Decimal              @db.Decimal(10, 2)
  currency      Currency             @default(FCFA)
  services      ReservationService[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model Service {
  id           String               @id @default(uuid())
  name         String
  price        Decimal              @db.Decimal(10, 2)
  currency     Currency             @default(FCFA)
  reservations ReservationService[]
}

model ReservationService {
  reservationId String
  serviceId     String
  quantity      Int         @default(1)
  date          DateTime?
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])

  @@id([reservationId, serviceId])
}

enum DepenseCategorie {
  FOURNITURES
  ALIMENTATION
  ENTRETIEN
  SALAIRES
  SERVICES
  EQUIPEMENT
  AUTRE
}

model Depense {
  id         String           @id @default(uuid())
  libelle    String
  montant    Decimal          @db.Decimal(10, 2)
  categorie  DepenseCategorie @default(AUTRE)
  date       DateTime         @default(now())
  note       String?
  createdBy  String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}
